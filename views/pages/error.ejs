<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= status %> — Safalam</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: #FBF6E9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .error-card {
            text-align: center;
            max-width: 480px;
            width: 100%;
        }

        .error-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 32px;
            color: #0D3D28;
            box-shadow: 0 4px 20px rgba(13,61,40,0.1);
        }

        .error-status {
            font-family: 'Playfair Display', serif;
            font-size: 80px;
            font-weight: 700;
            color: #0D3D28;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .error-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 0.75rem;
        }

        .error-message {
            font-size: 15px;
            color: #888;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .error-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .error-btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.75rem 1.75rem;
            background: #0D3D28;
            color: #fff;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s;
        }

        .error-btn-primary:hover {
            background: #0b3322;
            color: #fff;
        }

        .error-btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.75rem 1.75rem;
            background: #fff;
            color: #0D3D28;
            border: 1px solid #d0e8dc;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s;
        }

        .error-btn-secondary:hover {
            background: #f0f8f4;
        }

        .error-leaf {
            position: fixed;
            font-size: 120px;
            color: #0D3D28;
            opacity: 0.04;
            pointer-events: none;
        }

        .error-leaf-1 { top: -20px; left: -20px; transform: rotate(-20deg); }
        .error-leaf-2 { bottom: -20px; right: -20px; transform: rotate(160deg); }
    </style>
</head>
<body>

    <i class="fa-solid fa-leaf error-leaf error-leaf-1" aria-hidden="true"></i>
    <i class="fa-solid fa-leaf error-leaf error-leaf-2" aria-hidden="true"></i>

    <div class="error-card">

        <div class="error-icon">
            <% if(status === 404){ %>
                <i class="fa-regular fa-compass" aria-hidden="true"></i>
            <% } else if(status === 403){ %>
                <i class="fa-regular fa-lock" aria-hidden="true"></i>
            <% } else { %>
                <i class="fa-regular fa-triangle-exclamation" aria-hidden="true"></i>
            <% } %>
        </div>

        <p class="error-status"><%= status %></p>

        <h1 class="error-title"><%= title %></h1>

        <p class="error-message"><%= message %></p>

        <div class="error-actions">
            <a href="/" class="error-btn-primary">
                <i class="fa-solid fa-house" aria-hidden="true"></i>
                Go Home
            </a>
            <a href="javascript:history.back()" class="error-btn-secondary">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                Go Back
            </a>
        </div>

    </div>

</body>
</html>